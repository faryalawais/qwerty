{
  "name": "qwerty",
  "version": "0.0.1",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm -C apps/api run dev",
    "dev:web": "npm -C apps/web run dev",
    "build": "npm -C apps/api run build && npm -C apps/web run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "storybook": "npm -C apps/web run storybook",
    "lint": "eslint . --ext ts,tsx,js,jsx --cache",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.17.0",
    "concurrently": "^9.0.1",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}